# Copy to .env (git-ignored) and fill in. Used by llm_core (see llm_core/config.py).
#
# ARK_API_KEY authenticates the default model deepseek-v4-flash (Volcengine Ark)
# through LiteLLM. Without it, llm_core.llm_configured() is false and the LLM
# seam raises before any network call.
ARK_API_KEY=your-volcengine-ark-key-here

# Optional: override the .env path llm_core loads (defaults to this repo's .env).
# SCRIPTURE_LOOM_LLM_ENV=/absolute/path/to/.env
